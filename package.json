{
  "name": "modo-mapa",
  "private": true,
  "version": "2.35.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "firebase emulators:exec --only auth,firestore,functions,storage 'npm run dev'",
    "emulators": "firebase emulators:start --only auth,firestore,functions,storage",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest --maxWorkers=4",
    "test:run": "vitest run --maxWorkers=4",
    "test:coverage": "vitest run --coverage --maxWorkers=4",
    "seed": "cp scripts/seed-admin-data.ts functions/seed.ts && cd functions && npx tsx seed.ts; rm -f seed.ts",
    "analyze": "ANALYZE=true vite build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@sentry/react": "^10.45.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@vis.gl/react-google-maps": "^1.7.1",
    "browser-image-compression": "^2.0.2",
    "firebase": "^12.11.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3"
  }
}
