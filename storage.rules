rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Menu photos: owner-scoped uploads. Path includes userId for ownership validation.
    match /menus/{userId}/{businessId}/{fileName} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
      allow delete: if false; // Only Cloud Functions (admin SDK) can delete
    }

    // Legacy menu photos: read-only for existing photos uploaded before owner-scoping
    match /menus/{businessId}/{fileName} {
      allow read: if request.auth != null;
    }

    // Feedback media: owner can upload/delete (max 10MB). Path includes userId for ownership.
    match /feedback-media/{userId}/{feedbackId}/{fileName} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('(image/(jpeg|png|webp)|application/pdf)');
      allow delete: if request.auth != null
        && request.auth.uid == userId;
    }
  }
}
